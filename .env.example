# Local Quant Console example environment.
# Copy this file to .env only when you need local overrides.

LQC_APP_NAME=本地量化控制台
LQC_APP_VERSION=0.1.0
LQC_HOST=127.0.0.1
LQC_PORT=8000

# Keep runtime data out of Git.
LQC_DATA_DIR=data
LQC_LOG_DIR=logs
LQC_BACKUP_DIR=backups

# Configure real QMT locally in System Management or through a private .env.
# Do not commit real account IDs or local brokerage paths.
LQC_QMT_PATH=
LQC_QMT_ACCOUNT_ID=
